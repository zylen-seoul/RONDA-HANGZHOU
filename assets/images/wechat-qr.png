            </defs>
        </svg>
        <div style="
          max-width: 100%;
          width: 460px;
          padding: 0 16px;
          box-sizing: border-box;
        ">
            <h2 style="
            margin-bottom: 8px;
            color: #34322d;
            text-align: center;
            font-family: 'SF Pro';
            font-size: 18px;
            font-style: normal;
            font-weight: 600;
            line-height: 24px;
          ">
                This page is currently unavailable
            </h2>
            <p style="
            color: #858481;
            text-align: center;
            font-family: 'SF Pro';
            font-size: 14px;
            font-style: normal;
            font-weight: 500;
            line-height: 20px; /* 142.857% */
            letter-spacing: -0.154px;
          ">
                Please try refreshing or come back later.
            </p>
        </div>
    </div>
</body>

</html>